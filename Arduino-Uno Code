#include <Servo.h>

Servo servo1;

const int trigPin = 12;
const int echoPin = 11;
const int potPin = A0;

long duration;
int distance = 0;
int soil = 0;
int fsoil = 0;

int maxDryValue = 1;         // Humidity % above which it's considered wet
int Ultra_Distance = 15;     // Distance threshold for object detection (cm)

void setup() {
  Serial.begin(9600);
  pinMode(trigPin, OUTPUT); 
  pinMode(echoPin, INPUT); 
  servo1.attach(8);
  Serial.println("Soil Sensor     Ultrasonic          Servo");
}

void loop() {
  distance = 0;

  // Measure average distance (2 readings)
  for (int i = 0; i < 2; i++) {
    digitalWrite(trigPin, LOW);
    delayMicroseconds(7);
    digitalWrite(trigPin, HIGH);
    delayMicroseconds(10);
    digitalWrite(trigPin, LOW);
    delayMicroseconds(10);

    duration = pulseIn(echoPin, HIGH);
    distance += duration * 0.034 / 2;
    delay(10);
  }
  distance = distance / 2;

  // Proceed only if object is close enough
  if (distance < Ultra_Distance && distance > 1) {
    delay(1000);
    Serial.print("Object detected at ");
    Serial.print(distance);
    Serial.println(" cm. Checking moisture...");

    fsoil = 0;

    // Read soil moisture 3 times for averaging
    for (int i = 0; i < 3; i++) {
      soil = analogRead(potPin);

      // Handle disconnected sensor or no contact
      if (soil >= 1020) {
        Serial.println("No object on soil sensor or sensor disconnected. Skipping...");
        servo1.write(90);  // Neutral position
        delay(3000);
        return;
      }

      soil = constrain(soil, 485, 1023);
      fsoil += map(soil, 485, 1023, 100, 0);  // Convert to % humidity
      delay(75);
    }

    fsoil = fsoil / 3;

    Serial.print("Humidity: ");
    Serial.print(fsoil);
    Serial.print("%    Distance: ");
    Serial.print(distance);
    Serial.print(" cm");

    // Classify based on humidity
    if (fsoil > maxDryValue) {
      Serial.println("     ==> WET Waste");
      servo1.write(170);
    } else {
      Serial.println("     ==> DRY Waste");
      servo1.write(10);
    }

    delay(3000);
    servo1.write(90);  // Neutral position
  } else {
    Serial.println("No object detected near sensor.");
  }

  delay(1000);  // Delay between cycles
}
